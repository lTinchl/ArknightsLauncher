<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ArknightsLauncher.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="关于 Arknights Launcher"
    CloseButtonText="关闭"
    DefaultButton="Close"
    MinWidth="380">

    <StackPanel Spacing="16" MinWidth="340">

        <!-- Logo 区 -->
        <StackPanel HorizontalAlignment="Center" Spacing="6">
            <FontIcon Glyph="&#xE7FC;" FontSize="48"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                      HorizontalAlignment="Center"/>
            <TextBlock Text="Arknights Launcher"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionLabel"
                       Text="v1.3.5.2"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="By: Tinch"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       FontSize="12"/>
        </StackPanel>

        <NavigationViewItemSeparator/>

        <!-- 更新源选择 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="更新源：" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <ComboBox x:Name="SourceCombo"
                      Grid.Column="1"
                      SelectedIndex="0"
                      HorizontalAlignment="Stretch">
                <ComboBoxItem Content="GitHub（境外）"/>
                <ComboBoxItem Content="国内服务器（低速）"/>
            </ComboBox>
        </Grid>

        <!-- 检查更新按钮 -->
        <Button x:Name="BtnUpdate"
                Content="检查更新"
                HorizontalAlignment="Stretch"
                Style="{ThemeResource AccentButtonStyle}"
                Click="BtnUpdate_Click"/>

        <!-- 进度条（下载时显示）-->
        <ProgressBar x:Name="DownloadProgress"
                     Visibility="Collapsed"
                     Minimum="0"
                     Maximum="100"/>

        <!-- 状态文字 -->
        <TextBlock x:Name="UpdateStatusText"
                   Text=""
                   HorizontalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   FontSize="12"/>

    </StackPanel>
</ContentDialog>
