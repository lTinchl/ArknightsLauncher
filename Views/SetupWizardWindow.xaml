<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ArknightsLauncher.SetupWizardWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ArknightsLauncher"
    Title="Arknights Launcher - 初始设置">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop/>
    </Window.SystemBackdrop>

    <Grid>
        <!-- 主内容容器 -->
        <Grid Margin="32" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 标题区 -->
                <RowDefinition Height="Auto"/>
                <!-- 步骤指示器 -->
                <RowDefinition Height="*"/>
                <!-- 内容区 -->
                <RowDefinition Height="Auto"/>
                <!-- 按钮区 -->
            </Grid.RowDefinitions>

            <!-- ══════ 标题区 ══════ -->
            <StackPanel Grid.Row="0" Margin="0,16,0,24">
                <TextBlock Text="开始"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                <TextBlock Text="完成以下设置以开始使用"
                           FontSize="13"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ══════ 步骤指示器 ══════ -->
            <StackPanel Grid.Row="1" Margin="0,0,0,28">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StepLabel"
                               Text="步骤 1/2"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#4A9EFF"/>
                    <TextBlock x:Name="StepTitle"
                               Grid.Column="2"
                               Text="个性化"
                               FontSize="13"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                </Grid>

                <!-- 进度条 -->
                <Grid Height="2">
                    <Rectangle Fill="{ThemeResource SystemControlBackgroundBaseLowBrush}" RadiusX="1" RadiusY="1"/>
                    <Rectangle x:Name="StepProgressBar"
                               Fill="#4A9EFF"
                               RadiusX="1" RadiusY="1"
                               HorizontalAlignment="Left"
                               Width="258"/>
                </Grid>
            </StackPanel>

            <!-- ══════ 内容区 ══════ -->
            <Grid Grid.Row="2">

                <!-- 第1页：个性化 -->
                <StackPanel x:Name="Page1" Spacing="0" Visibility="Visible">

                    <TextBlock Text="个性化"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                               Margin="0,0,0,14"/>

                    <!-- 主题选择 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,14"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE771;" FontSize="18" Foreground="#4A9EFF"/>
                                <StackPanel>
                                    <TextBlock Text="主题" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBlock Text="选择应用的外观主题" FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="-20" VerticalAlignment="Center">
                                <RadioButton x:Name="ThemeLight" Content="浅色"
                                             FontSize="12"
                                             GroupName="Theme"
                                             Checked="ThemeRadio_Checked"/>
                                <RadioButton x:Name="ThemeDark" Content="深色"
                                             FontSize="12"
                                             GroupName="Theme" IsChecked="True"
                                             Checked="ThemeRadio_Checked"/>
                                <RadioButton x:Name="ThemeSystem" Content="跟随系统"
                                             FontSize="12"
                                             GroupName="Theme"
                                             Checked="ThemeRadio_Checked"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 窗口材质 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,14"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE790;" FontSize="18" Foreground="#4A9EFF"/>
                                <StackPanel>
                                    <TextBlock Text="窗口材质" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBlock Text="选择窗口背景模糊效果" FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <ComboBox x:Name="MaterialCombo"
                                      Grid.Column="2"
                                      MinWidth="100"
                                      SelectedIndex="1"
                                      SelectionChanged="MaterialCombo_SelectionChanged">
                                <ComboBoxItem Content="无"/>
                                <ComboBoxItem Content="亚克力"/>
                                <ComboBoxItem Content="云母"/>
                                <ComboBoxItem Content="云母Alt"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- 语言选择 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,14"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xF2B7;" FontSize="18" Foreground="#4A9EFF"/>
                                <StackPanel>
                                    <TextBlock Text="语言" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBlock Text="选择应用的显示语言" FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="-18" VerticalAlignment="Center">
                                <RadioButton x:Name="LangCN" Content="简体中文"
                                             FontSize="12"
                                             GroupName="Lang" IsChecked="True"/>
                                <RadioButton x:Name="LangEN" Content="English"
                                             FontSize="12"
                                             GroupName="Lang"
                                             IsEnabled="False"
                                             Opacity="0.4"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>

                <!-- 第2页：游戏路径 -->
                <StackPanel x:Name="Page2" Spacing="0" Visibility="Collapsed">

                    <TextBlock Text="游戏设置"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                               Margin="0,0,0,14"/>

                    <!-- 官服路径 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,16"
                            Margin="0,0,0,10">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE774;" FontSize="18" Foreground="#4A9EFF"/>
                                <StackPanel>
                                    <TextBlock Text="Arknights 路径" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBlock Text="Arknights游戏目录，包含versions、saves等文件夹"
                                               FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,8">
                                    <TextBlock x:Name="GamePathText"
                                               Text="未选择"
                                               FontSize="12"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                                <Button x:Name="BrowseGameBtn"
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Click="BrowseGameBtn_Click"
                                        Padding="12,8">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="13"/>
                                        <TextBlock Text="浏览" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- MAA路径 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18,16"
                            Margin="0,0,0,10">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE9D9;" FontSize="18" Foreground="#FF8800"/>
                                <StackPanel>
                                    <TextBlock Text="MAA 路径（官服）" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBlock Text="可选，选择 MAA.exe 以启用自动化脚本"
                                               FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,8">
                                    <TextBlock x:Name="MAAPathText"
                                               Text="未选择（可跳过）"
                                               FontSize="12"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                                <Button x:Name="BrowseMAABtn"
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Click="BrowseMAABtn_Click"
                                        Padding="12,8">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="13"/>
                                        <TextBlock Text="浏览" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </Grid>

            <!-- ══════ 底部按钮区 ══════ -->
            <Grid Grid.Row="3" Margin="0,20,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevBtn"
                        Content="上一步"
                        Padding="20,10"
                        CornerRadius="6"
                        IsEnabled="False"
                        Click="PrevBtn_Click"/>

                <Button x:Name="NextBtn"
                        Grid.Column="1"
                        Content="下一步"
                        Style="{ThemeResource AccentButtonStyle}"
                        Padding="28,10"
                        CornerRadius="6"
                        Click="NextBtn_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
