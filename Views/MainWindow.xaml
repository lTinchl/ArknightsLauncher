<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ArknightsLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ArknightsLauncher"
    Title="Arknights Launcher">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 装饰性背景光晕（保留，颜色中性，深浅都能看） -->
        <Ellipse Width="100" Height="100"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-200,-200,0"
                 Opacity="0.05">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#FF4A9EFF" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="200" Height="220"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="-120,0,0,-120"
                 Opacity="0.04">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#FF2B6CB0" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- ══════════════════════════════════════
             顶部标题栏
        ══════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧标题 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <FontIcon Glyph="&#xE7FC;" FontSize="20" Foreground="#4A9EFF"/>
                    <TextBlock Text="Arknights Launcher"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                               VerticalAlignment="Center"/>
                    <!-- 版本号徽章 -->
                    <Border Background="#334A9EFF"
                            BorderBrush="#554A9EFF"
                            BorderThickness="1"
                            CornerRadius="4" Padding="6,2">
                        <TextBlock x:Name="VersionText"
                                   Text="v1.3.5.2"
                                   Foreground="#4A9EFF"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <!-- 更新提示徽章 -->
                    <Border x:Name="UpdateBadge"
                            Background="#33FF9500"
                            BorderBrush="#55FF9500"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6,2"
                            Visibility="Collapsed">
                        <TextBlock x:Name="UpdateBadgeText"
                                   Text=""
                                   Foreground="#FF9500"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- 右侧按钮组 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="AccountMgrBtn"
                            Padding="14,8"
                            Background="#4A9EFF"
                            BorderThickness="0"
                            CornerRadius="6"
                            Click="AccountMgrBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE77B;" FontSize="13" Foreground="White"/>
                            <TextBlock Text="账号管理" FontSize="12" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="FixBtn"
                            Padding="14,8"
                            CornerRadius="6"
                            Click="FixBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE90F;" FontSize="13"/>
                            <TextBlock Text="修复客户端" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SettingsBtn"
                            Width="36" Height="36"
                            Padding="0"
                            CornerRadius="6"
                            Click="SettingsBtn_Click"
                            ToolTipService.ToolTip="设置">
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                    </Button>
                    <Button x:Name="AboutBtn"
                            Width="36" Height="36"
                            Padding="0"
                            CornerRadius="6"
                            Click="AboutBtn_Click"
                            ToolTipService.ToolTip="关于 / 检查更新">
                        <FontIcon Glyph="&#xE946;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             主内容区
        ══════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" Padding="24,20">
            <StackPanel Spacing="20">

                <!-- ── 启动游戏 区块 ── -->
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="2,0,0,0">
                        <Rectangle Width="3" Height="18" Fill="#4A9EFF" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                        <TextBlock Text="启动游戏"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 官服卡片 -->
                        <Border Grid.Column="0" Grid.Row="0"
                                Margin="0,0,8,8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="#1A4A9EFF" CornerRadius="8"
                                            Width="40" Height="40"
                                            Margin="0,0,10,0">
                                        <FontIcon Glyph="&#xE774;" FontSize="20" Foreground="#4A9EFF"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="官服" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                        <TextBlock Text="明日方舟 · 官方服务器"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="账号："
                                               FontSize="12"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>

                                    <ComboBox x:Name="AccountCombo"
                                              Grid.Column="3"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              FontSize="12"
                                              SelectionChanged="AccountCombo_SelectionChanged"/>
                                </Grid>

                                <Button x:Name="OfficialBtn"
                                        HorizontalAlignment="Stretch"
                                        Background="#4A9EFF"
                                        BorderThickness="0"
                                        CornerRadius="8"
                                        Padding="0,10"
                                        Click="OfficialBtn_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE768;" FontSize="13" Foreground="White"/>
                                        <TextBlock Text="启动官服" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- B服卡片 -->
                        <Border Grid.Column="1" Grid.Row="0"
                                Margin="8,0,0,8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Background="#1AFF3399" CornerRadius="8" Width="40" Height="40">
                                        <FontIcon Glyph="&#xE8EF;" FontSize="20" Foreground="#FF3399"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="B服" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                        <TextBlock Text="明日方舟 · 哔哩哔哩服务器"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button x:Name="BServerBtn"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="8"
                                        Padding="0,10"
                                        IsEnabled="False"
                                        Click="BServerBtn_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE768;" FontSize="13"/>
                                        <TextBlock Text="启动B服" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- MAA-官 卡片 -->
                        <Border Grid.Column="0" Grid.Row="1"
                                Margin="0,0,8,0"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Background="#1AFF8800" CornerRadius="8" Width="40" Height="40">
                                        <FontIcon Glyph="&#xE9D9;" FontSize="20" Foreground="#FF8800"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="MAA · 官服" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                        <TextBlock Text="自动化脚本"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button x:Name="MAAOfficialBtn"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="8"
                                        Padding="0,10"
                                        Click="MAAOfficialBtn_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE768;" FontSize="13"/>
                                        <TextBlock Text="启动 MAA（官服）" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- MAA-B 卡片 -->
                        <Border Grid.Column="1" Grid.Row="1"
                                Margin="8,0,0,0"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18">
                            <StackPanel Spacing="14">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Background="#1AFF3399" CornerRadius="8" Width="40" Height="40">
                                        <FontIcon Glyph="&#xE9D9;" FontSize="20" Foreground="#FF3399"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="MAA · B服" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                        <TextBlock Text="自动化脚本"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button x:Name="MAABServerBtn"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="8"
                                        Padding="0,10"
                                        Click="MAABServerBtn_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xE768;" FontSize="13"/>
                                        <TextBlock Text="启动 MAA（B服）" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ── 工具链接 区块 ── -->
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="2,0,0,0">
                        <Rectangle Width="3" Height="18" Fill="#4A9EFF" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                        <TextBlock Text="工具链接"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <ItemsRepeater x:Name="LinksRepeater">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="130" MinColumnSpacing="8" MinRowSpacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:LinkItem">
                                <Button HorizontalAlignment="Stretch"
                                        Tag="{x:Bind Url}"
                                        Click="LinkBtn_Click"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,14">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <FontIcon Glyph="{x:Bind Glyph}"
                                                  FontSize="22"
                                                  Foreground="#4A9EFF"/>
                                        <TextBlock Text="{x:Bind Title}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                                   TextAlignment="Center"
                                                   TextWrapping="NoWrap"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════════════════
             底部状态栏
        ══════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Text=""
                           FontSize="12"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>

                <ProgressBar x:Name="StatusProgress"
                             Grid.Column="1"
                             Width="160"
                             IsIndeterminate="False"
                             Visibility="Collapsed"
                             VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 启动进度遮罩 (全屏) -->
        <Grid x:Name="LaunchOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Background="{ThemeResource SystemControlPageBackgroundMediumAltMediumBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="40,32">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <ProgressRing IsActive="True"
                                      Width="44" Height="44"
                                      Foreground="#4A9EFF"/>
                        <TextBlock x:Name="LaunchStatusText"
                                   Text="正在启动…"
                                   Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
