<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ArknightsLauncher.AccountManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ArknightsLauncher"
    Title="账号管理"
    CloseButtonText="关闭"
    DefaultButton="Close"
    MinWidth="460">

    <StackPanel Spacing="12" MinWidth="420" MaxWidth="520">

        <!-- 提示文字 -->
        <InfoBar IsOpen="True"
                 IsClosable="False"
                 Severity="Informational"
                 Message="双击列表项可快速重命名账号"/>

        <!-- 账号列表 -->
        <ListView x:Name="AccountList"
                  Height="220"
                  SelectionMode="Single"
                  DoubleTapped="AccountList_DoubleTapped"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="4">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Remark}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Id}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 操作按钮（第一行） -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="BtnAdd"
                    Content="新增账号"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="BtnAdd_Click"/>
            <Button x:Name="BtnRename"
                    Content="重命名"
                    Click="BtnRename_Click"/>
            <Button x:Name="BtnSetDefault"
                    Content="设为默认"
                    Click="BtnSetDefault_Click"/>
        </StackPanel>

        <!-- 操作按钮（第二行） -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="BtnBackup"
                    Content="备份当前账号"
                    Click="BtnBackup_Click"/>
            <Button x:Name="BtnDelete"
                    Content="删除"
                    Foreground="Red"
                    Click="BtnDelete_Click"/>
        </StackPanel>

    </StackPanel>
</ContentDialog>
